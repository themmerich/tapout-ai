# Normalize all text files to LF in the repository and working tree.
# Matches Prettier (endOfLine: lf) and .editorconfig, and prevents CRLF/LF
# churn on Windows where core.autocrlf would otherwise check out CRLF.
* text=auto eol=lf

# Windows batch files need CRLF; the Gradle wrapper script stays LF.
*.bat text eol=crlf
gradlew text eol=lf

# Binary assets — never apply EOL conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.woff  binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.jar  binary
